generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Expense {
  id          String   @id @default(cuid())
  amountCents Int
  category    String
  note        String?
  spentAt     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
